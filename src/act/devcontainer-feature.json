{
  "id": "act",
  "version": "0.1.2",
  "name": "act",
  "description": "Installs act, a tool to run GitHub Actions locally.",
  "documentationURL": "https://github.com/SrzStephen/devcontainer-features/blob/main/src/act/README.md",
  "keywords": [
    "act",
    "github-actions",
    "ci",
    "local"
  ],
  "options": {
    "version": {
      "type": "string",
      "proposals": [
        "latest",
        "0"
      ],
      "default": "latest",
      "description": "Version of act to install. Use 'latest' for the newest available."
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}
