{
  "id": "kiro-cli",
  "version": "0.1.3",
  "name": "Kiro CLI",
  "description": "Installs the Kiro cli.",
  "documentationURL": "https://github.com/SrzStephen/devcontainer-features/blob/main/src/kiro-cli/README.md",
  "keywords": [
    "kiro",
    "aws",
    "ai",
    "cli",
    "coding-assistant"
  ],
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ],
  "options": {
    "version": {
      "type": "string",
      "proposals": [
        "latest",
        "2.3.0"
      ],
      "default": "latest",
      "description": "Version of Kiro CLI to install. Use 'latest' for the newest available, or a full version like '2.3.0'."
    },
    "disableAutoupdates": {
      "type": "boolean",
      "default": false,
      "description": "Disable automatic background updates for Kiro CLI."
    }
  }
}
